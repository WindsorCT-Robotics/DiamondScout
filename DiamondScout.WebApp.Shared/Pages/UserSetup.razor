@page "/usersetup"
@using ParagonRobotics.DiamondScout.Common

<h3>Tablet Setup</h3>

<div class="container">

    <div class="mb-3">
        <label>Scouter Name</label>
        <input class="form-control" @bind="Name" />
    </div>

    <div class="mb-3">
        <label>Role</label>
        <select class="form-select" @bind="SelectedRole">
            <option value="Scouter">Scouter</option>
            <option value="Admin">Admin</option>
            <option value="Viewer">Viewer</option>
        </select>
    </div>

    <button class="btn btn-primary" @onclick="InitializeTablet">
        Initialize
    </button>

    <div class="reset-modal">
        <h3>Reset User Data</h3>

        <input type="password"
               @bind="ResetPassword"
               placeholder="Enter admin password"/>

        <button @onclick="ConfirmResetPassword">Confirm Reset</button>
        <button @onclick="() => ShowResetPasswordPrompt = false">Cancel</button>

        @if (!string.IsNullOrEmpty(ResetError))
        {
            <p style="color:red">@ResetError</p>
        }
    </div>
</div>