@page "/matchscout"
@using ParagonRobotics.DiamondScout.Common
@using Microsoft.AspNetCore.Components.Forms
@using ParagonRobotics.DiamondScout


<div class="mb-6">
    <h1>Match Scouting</h1>
</div>
<br/>
<div class="mb-6">
    <details id="setup" class="mb-6" open>
        <summary><h1>Setup</h1></summary>

        <label for="teamNumber">Team Number:</label>
        <input type="number" id="teamNumber" min="1" max="99999" @bind="TeamNumber" />
        <p>Selected team number: @TeamNumber</p>

        <br/>

        <label for="alliance">Alliance:</label>
        <select id="alliance" @bind="SelectedAlliance">
            @foreach (var alliance in AllianceOptions)
            {
                <option value="@alliance">@alliance</option>
            }
        </select>

        <p>Selected alliance: @SelectedAlliance</p>
    </details>

    <br/>

    <details id="auto" class="mb-6">
        <summary><h1>Autonomous</h1></summary>

        <label for="startpos">Starting Position:</label>
        <select id="startpos" @bind="StartingPosition">
            @foreach (var startpos in StartingOptions)
            {
                <option value="@startpos">@startpos</option>
            }
        </select>
        <p>Starting Position: @StartingPosition</p>
        <br/>

        <label for="prefuel">Preload Fuel?</label>
        <select id="prefuel" @bind="PreloadedFuel">
            @foreach (var prefuel in IsFuelLoaded)
            {
                <option value="@prefuel">@prefuel</option>
            }
        </select>
        <p>Preloaded Fuel: @PreloadedFuel</p>
        <br/>

        <label for="shotfuel">Is Fuel Shot?</label>
        <select id="shotfuel" @bind="ShotFuel">
            @foreach (var shotfuel in IsFuelShot)
            {
                <option value="@shotfuel">@shotfuel</option>
            }
        </select>
        <p>Fuel Shot: @ShotFuel</p>
        <br/>

        <label for="autoAccuracy">How Is Their Auto Shooting Accuracy?</label>
        <select id="autoAccuracy"
                value="@AutoShootingAccuracyDisplay"
                @onchange="OnAutoAccuracyChanged">
            @foreach (var option in AutoAccuracyOptions)
            {
                <option value="@option.Label">@option.Label</option>
            }
        </select>
        <p>Auto Shooting Accuracy: @AutoShootingAccuracyDisplay</p>
        <br/>

        <label for="collectedFuel">Is More Fuel Collected?</label>
        <select id="collectedFuel" @bind="CollectedFuel">
            @foreach (var collectedfuel in IsMoreFuelCollected)
            {
                <option value="@collectedfuel">@collectedfuel</option>
            }
        </select>
        <p>Fuel Collected: @CollectedFuel</p>
        <br/>

        <label for="autoL1Climb">Do They Climb to L1?</label>
        <select id="autoL1Climb"
                value="@AutoL1ClimbDisplay"
                @onchange="OnAutoL1ClimbChanged">
            @foreach (var option in AutoL1ClimbOptions)
            {
                <option value="@option">@option</option>
            }
        </select>
        <p>Auto L1 Climb: @AutoL1ClimbDisplay</p>
    </details>

    <br/>

    <details id="tele" class="mb-6">
        <summary><h1>Teleop</h1></summary>
        <br/>
        <div id="activehub">
            <h2>Active Hub</h2>

            <label for="teleopFuelPerCycle">How Much Fuel Do They Shoot in One Cycle?</label>
            <select id="teleopFuelPerCycle"
                    value="@TeleopFuelPerCycleDisplay"
                    @onchange="OnTeleopFuelPerCycleChanged">
                @foreach (var option in TeleopFuelPerCycleOptions)
                {
                    <option value="@option.Label">@option.Label</option>
                }
            </select>
            <p>Fuel Per Cycle: @TeleopFuelPerCycleDisplay</p>
            <br/>

            <label for="teleopAccuracy">How is Their Teleop Shooting Accuracy?</label>
            <select id="teleopAccuracy"
                    value="@TeleopShootingAccuracyDisplay"
                    @onchange="OnTeleopShootingAccuracyChanged">
                @foreach (var option in TeleopAccuracyOptions)
                {
                    <option value="@option.Label">@option.Label</option>
                }
            </select>
            <p>Teleop Shooting Accuracy: @TeleopShootingAccuracyDisplay</p>
            <br/>

            <label for="shootingWhileMoving">Are They Shooting While Moving?</label>
            <select id="shootingWhileMoving" @bind="ShootingWhileMovingDisplay">
                @foreach (var option in YesNoOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
            <p>Shooting While Moving: @ShootingWhileMovingDisplay</p>
            <br/>

            <label for="certainPositionsOnly">Are They Shooting Only From Certain Positions?</label>
            <select id="certainPositionsOnly" @bind="ShootingFromCertainPositionsOnlyDisplay">
                @foreach (var option in YesNoOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
            <p>Shooting From Certain Positions Only: @ShootingFromCertainPositionsOnlyDisplay</p>
            <br/>

            <label for="teleopCycles">How Many Cycles Did They Do?</label>
            <div>
                <button type="button" @onclick="DecrementTeleopCycleCount">-</button>
                <input id="teleopCycles" type="number" min="0" @bind="TeleopCycleCount" />
                <button type="button" @onclick="IncrementTeleopCycleCount">+</button>
            </div>
            <p>Total Throughout Game: @TeleopCycleCount</p>
            <br/>

            <label for="defensePlayed">Did They Have Defense Played Against Them?</label>
            <select id="defensePlayed" @bind="DefensePlayedAgainstThemDisplay">
                @foreach (var option in YesNoOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
            <p>Defense Played Against Them: @DefensePlayedAgainstThemDisplay</p>

            <br/>

            <label for="defenseHandling">How Well Did They Handle Defense Being Played Against Them?</label>
            <select id="defenseHandling"
                    value="@DefenseHandlingDisplay"
                    @onchange="OnDefenseHandlingChanged">
                @foreach (var option in DefenseHandlingOptions)
                {
                    <option value="@option.Label">@option.Label</option>
                }
            </select>
            <p>Defense Handling: @DefenseHandlingDisplay</p>
        </div>

        <br/>

        <div id="inactivehub">
            <h2>Inactive Hub</h2>
        </div>
    </details>

    <br/>

    <details id="endgame" class="mb-6">
        <summary><h1>Endgame</h1></summary>

        <label for="endgameClimb">Endgame Climb</label>
        <select id="endgameClimb"
                value="@EndgameClimbDisplay"
                @onchange="OnEndgameClimbChanged">
            @foreach (var option in EndgameClimbOptions)
            {
                <option value="@option">@option</option>
            }
        </select>
        <p>Endgame Climb: @EndgameClimbDisplay</p>
    </details>

    <br/>

    <details id="overall" class="mb-6">
        <summary><h1>Overall</h1></summary>

        <label for="driverSkill">How Was Their Driver’s Skill?</label>
        <select id="driverSkill"
                value="@DriverSkillDisplay"
                @onchange="OnDriverSkillChanged">
            @foreach (var option in DriverSkillOptions)
            {
                <option value="@option.Label">@option.Label</option>
            }
        </select>
        <p>Driver Skill: @DriverSkillDisplay</p>

        <br/>

        <label for="robotReliability">How Reliable Was Their Robot During The Match?</label>
        <select id="robotReliability"
                value="@RobotReliabilityDisplay"
                @onchange="OnRobotReliabilityChanged">
            @foreach (var option in RobotReliabilityOptions)
            {
                <option value="@option.Label">@option.Label</option>
            }
        </select>
        <p>Robot Reliability: @RobotReliabilityDisplay</p>

        <br/>

        <label for="hadRobotIssues">Did They Have Robot Issues During The Match?</label>
        <select id="hadRobotIssues" @bind="HadRobotIssuesDisplay">
            @foreach (var option in YesNoOptions)
            {
                <option value="@option">@option</option>
            }
        </select>
        <p>Had Robot Issues: @HadRobotIssuesDisplay</p>

        <br/>

        @if (ShowRobotIssuesText)
        {
            <label for="robotIssuesText">What Robot Issues Did You See?</label>
            <textarea id="robotIssuesText" rows="4" cols="50" @bind="RobotIssuesText"></textarea>
            <p>Robot Issues: @RobotIssuesText</p>

            <br/>
        }

        <label for="additionalThoughtsText">Any Additional Thoughts On This Robot?</label>
        <textarea id="additionalThoughtsText" rows="4" cols="50" @bind="AdditionalThoughtsText"></textarea>
        <p>Additional Thoughts: @AdditionalThoughtsText</p>
    </details>

    <br/>

    <div class="mb-6">
        <button type="button" @onclick="GenerateQrPayload">Generate QR Code</button>

        @if (!string.IsNullOrWhiteSpace(QrGenerationError))
        {
            <p style="color: red;">QR generation error: @QrGenerationError</p>
        }
	</div>
<DiamondScout.WebApp.Shared.Components.QrCodeModal IsOpen="@IsQrModalOpen"
                                                   QrSvg="@GeneratedQrSvg"
                                                   OnClose="CloseQrModal" />
</div>
