@namespace DiamondScout.WebApp.Shared.Components
@using Microsoft.AspNetCore.Components

@if (IsOpen && !string.IsNullOrWhiteSpace(QrSvg))
{
    <div class="qr-modal-backdrop" @onclick="OnCloseClicked">
        <div class="qr-modal-shell" @onclick:stopPropagation="true">
            <div class="qr-modal-header">
                <button type="button" class="qr-close-button" @onclick="OnCloseClicked">Close</button>
            </div>

            <div class="qr-modal-body">
                <div class="qr-square">
                    <div class="qr-svg-wrapper">
                        @((MarkupString)QrSvg)
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .qr-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.78);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        box-sizing: border-box;
        z-index: 2000;
    }

    .qr-modal-shell {
        width: min(96vw, 96vh);
        height: min(96vw, 96vh);
        max-width: 100%;
        max-height: 100%;
        background: white;
        border-radius: 12px;
        box-shadow: 0 0.75rem 2rem rgba(0, 0, 0, 0.35);
        overflow: hidden;
        display: grid;
        grid-template-rows: auto 1fr;
        box-sizing: border-box;
    }

    .qr-modal-header {
        display: flex;
        justify-content: flex-end;
        padding: 0.75rem 0.75rem 0 0.75rem;
        box-sizing: border-box;
    }

    .qr-close-button {
        flex: 0 0 auto;
        padding: 0.4rem 0.75rem;
    }

    .qr-modal-body {
        min-width: 0;
        min-height: 0;
        padding: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        box-sizing: border-box;
    }

    .qr-square {
        width: 100%;
        height: 100%;
        aspect-ratio: 1 / 1;
        max-width: 100%;
        max-height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .qr-svg-wrapper {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .qr-svg-wrapper svg {
        display: block;
        max-width: 100%;
        max-height: 100%;
        width: 100%;
        height: 100%;
    }

    @@media (max-width: 600px) {
        .qr-modal-shell {
            width: 98vw;
            height: 98vh;
        }
    }
</style>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string? QrSvg { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private async Task OnCloseClicked()
    {
        await OnClose.InvokeAsync();
    }
}